{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MS Control Center",
  "version": "0.1.0",
  "identifier": "com.proyectsplus.ms-control-center",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MS Control Center",
        "label": "main",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
